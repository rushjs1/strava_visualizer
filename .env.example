# Private personal Strava analytics only.
# Create a Strava API app, then set these for the OAuth connect flow.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional fallback for quick server-side testing. OAuth storage is preferred.
STRAVA_ACCESS_TOKEN=

# Production token storage. Use this on Netlify.
# Generate a long random value, for example: openssl rand -base64 32
STRAVA_TOKEN_STORAGE=netlify-blobs
TOKEN_ENCRYPTION_KEY=
